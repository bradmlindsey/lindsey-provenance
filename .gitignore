# Python
__pycache__/
*.py[cod]
*.so
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/

# lindsey-provenance project content (these are user data, not framework code)
# When you `lindsey-provenance init` somewhere else, those folders should commit.
# But inside THIS repo (the framework repo), we don't ship user projects.
operator/projects/_*selftest*/
operator/proof_state_ledger/*.jsonl
!operator/proof_state_ledger/.gitkeep

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp

# Keys — never commit private keys. The PUBLIC key (keys/*.pub) IS committed
# so anyone can verify the authorship signatures.
*.key
keys/*.key
